<Window x:Class="AutoDocumentation.Views.ElementReportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=""
        Width="440"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource App_Background}"
        Foreground="{DynamicResource App_Foreground}"
        ShowInTaskbar="False">
  <Grid Margin="18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0"
               TextWrapping="Wrap"
               Foreground="{DynamicResource App_MutedForeground}"
               FontSize="12"
               x:Name="DescriptionText" />

    <TextBlock Grid.Row="1"
               x:Name="NotesLabel"
               Margin="0,14,0,0"
               Text=""
               Foreground="{DynamicResource App_MutedForeground}"
               FontSize="12" />
    <TextBox Grid.Row="2"
             x:Name="UserNotesTextBox"
             Margin="0,6,0,16"
             MinLines="3"
             MaxLines="6"
             MaxHeight="100"
             TextWrapping="Wrap"
             AcceptsReturn="True"
             VerticalScrollBarVisibility="Auto"
             Padding="10,8"
             FontSize="12"
             Background="{DynamicResource Surface_Default}"
             Foreground="{DynamicResource App_Foreground}"
             BorderBrush="{DynamicResource Border_Default}"
             CaretBrush="{DynamicResource App_Foreground}" />

    <StackPanel Grid.Row="3"
                Orientation="Horizontal"
                HorizontalAlignment="Right">
      <Button x:Name="CancelButton"
              MinWidth="96"
              Height="34"
              Margin="0,0,10,0"
              Padding="12,0"
              Background="{DynamicResource Btn_Secondary_Background}"
              Foreground="{DynamicResource Btn_Secondary_Foreground}"
              BorderThickness="0"
              IsCancel="True"
              Click="Cancel_Click"
              Content="" />
      <Button x:Name="SaveButton"
              MinWidth="140"
              Height="34"
              Padding="12,0"
              Background="{DynamicResource Btn_Primary_Background}"
              Foreground="{DynamicResource Btn_Primary_Foreground}"
              BorderThickness="0"
              FontWeight="SemiBold"
              Click="Ok_Click"
              Content="" />
    </StackPanel>
  </Grid>
</Window>
