<Window x:Class="AutoDocumentation.Views.EditTeamParameterDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Editar parâmetro"
        Width="480"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FF1C1C1E"
        Foreground="#FFF2F2F7"
        ShowInTaskbar="False">
  <Window.Resources>
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#FF2C2C2E" />
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#FFF2F2F7" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#FF2C2C2E" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#FFF2F2F7" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightBrushKey}" Color="#FF2C2C2E" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightLightBrushKey}" Color="#FF2C2C2E" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkBrushKey}" Color="#FF48484A" />
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FF0A84FF" />
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White" />
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#FF244060" />
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#FFF2F2F7" />

    <Style x:Key="DarkComboBoxItemStyle" TargetType="ComboBoxItem">
      <Setter Property="Background" Value="#FF2C2C2E" />
      <Setter Property="Foreground" Value="#FFF2F2F7" />
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="FontSize" Value="13" />
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#FF3A3A3C" />
        </Trigger>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="#FF244060" />
          <Setter Property="Foreground" Value="#FFFFFFFF" />
          <Setter Property="FontWeight" Value="SemiBold" />
        </Trigger>
        <Trigger Property="IsHighlighted" Value="True">
          <Setter Property="Background" Value="#FF0A84FF" />
          <Setter Property="Foreground" Value="White" />
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="DarkTeamComboBoxStyle" TargetType="ComboBox">
      <Setter Property="Foreground" Value="#FFF2F2F7" />
      <Setter Property="Background" Value="#FF2C2C2E" />
      <Setter Property="BorderBrush" Value="#FF48484A" />
      <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
      <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
      <Setter Property="Padding" Value="10,8,28,8" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ComboBox">
            <Grid SnapsToDevicePixels="True">
              <Popup x:Name="PART_Popup"
                     AllowsTransparency="True"
                     Focusable="False"
                     IsOpen="{TemplateBinding IsDropDownOpen}"
                     Placement="Bottom"
                     PopupAnimation="Slide">
                <Grid MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                      MaxHeight="{TemplateBinding MaxDropDownHeight}"
                      SnapsToDevicePixels="True">
                  <Border Background="#FF2C2C2E"
                          BorderBrush="#FF48484A"
                          BorderThickness="1"
                          Margin="0,2,0,0">
                    <ScrollViewer SnapsToDevicePixels="True">
                      <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                    </ScrollViewer>
                  </Border>
                </Grid>
              </Popup>
              <ToggleButton x:Name="ToggleButton"
                            Focusable="False"
                            ClickMode="Press"
                            IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                <ToggleButton.Template>
                  <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="ToggleBorder"
                            Background="#FF2C2C2E"
                            BorderBrush="#FF48484A"
                            BorderThickness="1"
                            SnapsToDevicePixels="True">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="22" />
                        </Grid.ColumnDefinitions>
                        <ContentPresenter Grid.Column="0"
                                          Margin="10,8,4,8"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True"
                                          Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                          ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                          ContentTemplateSelector="{Binding SelectionBoxItemTemplateSelector, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                          TextElement.Foreground="#FFF2F2F7" />
                        <Path Grid.Column="1"
                              Margin="0,0,8,0"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Fill="#FFF2F2F7"
                              Data="M 0 1 L 4 5 L 8 1 Z" />
                      </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                      <DataTrigger Binding="{Binding IsKeyboardFocusWithin, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                   Value="True">
                        <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="#FF0A84FF" />
                      </DataTrigger>
                    </ControlTemplate.Triggers>
                  </ControlTemplate>
                </ToggleButton.Template>
              </ToggleButton>
            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.55" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>
  <Grid Margin="18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0"
               TextWrapping="Wrap"
               Foreground="#FFAEAEB2"
               FontSize="12"
               x:Name="IntroText" />

    <TextBlock Grid.Row="1"
               Margin="0,12,0,0"
               Text="Nome"
               Foreground="#FFAEAEB2"
               FontSize="12" />
    <TextBox Grid.Row="2"
             x:Name="NewNameTextBox"
             Margin="0,6,0,12"
             Padding="10,8"
             FontSize="13"
             Background="#FF2C2C2E"
             Foreground="#FFF2F2F7"
             BorderBrush="#FF48484A"
             CaretBrush="#FFF2F2F7" />

    <TextBlock Grid.Row="3"
               Text="Tipo de dados"
               Foreground="#FFAEAEB2"
               FontSize="12" />
    <ComboBox Grid.Row="4"
              x:Name="KindComboBox"
              Style="{StaticResource DarkTeamComboBoxStyle}"
              Margin="0,6,0,12"
              FontSize="13"
              ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}" />

    <CheckBox Grid.Row="5"
              x:Name="ExtendCategoriesCheckBox"
              Margin="0,0,0,10"
              Foreground="#FFAEAEB2"
              FontSize="12"
              Content="+ Categorias da selecção desta janela"
              ToolTip="Adiciona ao parâmetro as categorias Revit dos elementos que estão seleccionados no assistente (paredes, portas, etc.), para o parâmetro passar a existir também nesses tipos — além das categorias já ligadas ao projecto." />

    <TextBlock Grid.Row="6"
               TextWrapping="Wrap"
               Foreground="#FF8E8E93"
               FontSize="11"
               Margin="0,0,0,14"
               Text="Se mudar só o tipo com o mesmo nome, o assistente pergunta se há elementos fora da selecção: pode limpar valores nesses elementos ou criar um parâmetro novo só para a selecção. Os valores são repostos quando possível após a conversão." />

    <StackPanel Grid.Row="7"
                Orientation="Horizontal"
                HorizontalAlignment="Right">
      <Button MinWidth="96"
              Height="34"
              Margin="0,0,10,0"
              Padding="12,0"
              Background="#FF3A3A3C"
              Foreground="#FFF2F2F7"
              BorderThickness="0"
              IsCancel="True"
              Click="Cancel_Click"
              Content="Cancelar" />
      <Button MinWidth="96"
              Height="34"
              Padding="12,0"
              Background="#FF0A84FF"
              Foreground="White"
              BorderThickness="0"
              FontWeight="SemiBold"
              Click="Ok_Click"
              Content="OK" />
    </StackPanel>
  </Grid>
</Window>
