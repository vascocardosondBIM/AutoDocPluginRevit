<Window x:Class="AutoDocumentation.Views.EditTeamParameterDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=""
        Width="480"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource App_Background}"
        Foreground="{DynamicResource App_Foreground}"
        ShowInTaskbar="False">
  <Window.Resources>
    <Style x:Key="DarkComboBoxItemStyle" TargetType="ComboBoxItem">
      <Setter Property="Background" Value="{DynamicResource Surface_Default}" />
      <Setter Property="Foreground" Value="{DynamicResource App_Foreground}" />
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="FontSize" Value="13" />
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="{DynamicResource Btn_Secondary_Background}" />
        </Trigger>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="{DynamicResource DataGrid_RowSelected}" />
          <Setter Property="Foreground" Value="{DynamicResource Btn_Primary_Foreground}" />
          <Setter Property="FontWeight" Value="SemiBold" />
        </Trigger>
        <Trigger Property="IsHighlighted" Value="True">
          <Setter Property="Background" Value="{DynamicResource Btn_Primary_Background}" />
          <Setter Property="Foreground" Value="{DynamicResource Btn_Primary_Foreground}" />
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="DarkTeamComboBoxStyle" TargetType="ComboBox">
      <Setter Property="Foreground" Value="{DynamicResource App_Foreground}" />
      <Setter Property="Background" Value="{DynamicResource Combo_Surface}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Combo_Border}" />
      <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
      <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
      <Setter Property="Padding" Value="10,8,28,8" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ComboBox">
            <Grid SnapsToDevicePixels="True">
              <Popup x:Name="PART_Popup"
                     AllowsTransparency="True"
                     Focusable="False"
                     IsOpen="{TemplateBinding IsDropDownOpen}"
                     Placement="Bottom"
                     PopupAnimation="Slide">
                <Grid MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                      MaxHeight="{TemplateBinding MaxDropDownHeight}"
                      SnapsToDevicePixels="True">
                  <Border Background="{DynamicResource Combo_Surface}"
                          BorderBrush="{DynamicResource Combo_Border}"
                          BorderThickness="1"
                          Margin="0,2,0,0">
                    <ScrollViewer SnapsToDevicePixels="True">
                      <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                    </ScrollViewer>
                  </Border>
                </Grid>
              </Popup>
              <ToggleButton x:Name="ToggleButton"
                            Focusable="False"
                            ClickMode="Press"
                            IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                <ToggleButton.Template>
                  <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="ToggleBorder"
                            Background="{DynamicResource Combo_Surface}"
                            BorderBrush="{DynamicResource Combo_Border}"
                            BorderThickness="1"
                            SnapsToDevicePixels="True">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="22" />
                        </Grid.ColumnDefinitions>
                        <ContentPresenter Grid.Column="0"
                                          Margin="10,8,4,8"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True"
                                          Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                          ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                          ContentTemplateSelector="{Binding SelectionBoxItemTemplateSelector, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                          TextElement.Foreground="{DynamicResource App_Foreground}" />
                        <Path Grid.Column="1"
                              Margin="0,0,8,0"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Fill="{DynamicResource Combo_ArrowFill}"
                              Data="M 0 1 L 4 5 L 8 1 Z" />
                      </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                      <DataTrigger Binding="{Binding IsKeyboardFocusWithin, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                   Value="True">
                        <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{DynamicResource Border_Focus}" />
                      </DataTrigger>
                    </ControlTemplate.Triggers>
                  </ControlTemplate>
                </ToggleButton.Template>
              </ToggleButton>
            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.55" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>
  <Grid Margin="18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0"
               TextWrapping="Wrap"
               Foreground="{DynamicResource App_MutedForeground}"
               FontSize="12"
               x:Name="IntroText" />

    <TextBlock x:Name="NameLabel"
               Grid.Row="1"
               Margin="0,12,0,0"
               Text=""
               Foreground="{DynamicResource App_MutedForeground}"
               FontSize="12" />
    <TextBox Grid.Row="2"
             x:Name="NewNameTextBox"
             Margin="0,6,0,12"
             Padding="10,8"
             FontSize="13"
             Background="{DynamicResource Surface_Default}"
             Foreground="{DynamicResource App_Foreground}"
             BorderBrush="{DynamicResource Border_Default}"
             CaretBrush="{DynamicResource App_Foreground}" />

    <TextBlock x:Name="KindLabel"
               Grid.Row="3"
               Text=""
               Foreground="{DynamicResource App_MutedForeground}"
               FontSize="12" />
    <ComboBox Grid.Row="4"
              x:Name="KindComboBox"
              Style="{StaticResource DarkTeamComboBoxStyle}"
              Margin="0,6,0,12"
              FontSize="13"
              ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}" />

    <CheckBox Grid.Row="5"
              x:Name="ExtendCategoriesCheckBox"
              Margin="0,0,0,10"
              Foreground="{DynamicResource App_MutedForeground}"
              FontSize="12"
              Content=""
              ToolTip="" />

    <TextBlock x:Name="FooterHelpText"
               Grid.Row="6"
               TextWrapping="Wrap"
               Foreground="{DynamicResource App_SubtleForeground}"
               FontSize="11"
               Margin="0,0,0,14"
               Text="" />

    <StackPanel Grid.Row="7"
                Orientation="Horizontal"
                HorizontalAlignment="Right">
      <Button x:Name="CancelButton"
              MinWidth="96"
              Height="34"
              Margin="0,0,10,0"
              Padding="12,0"
              Background="{DynamicResource Btn_Secondary_Background}"
              Foreground="{DynamicResource Btn_Secondary_Foreground}"
              BorderThickness="0"
              IsCancel="True"
              Click="Cancel_Click"
              Content="" />
      <Button x:Name="OkButton"
              MinWidth="96"
              Height="34"
              Padding="12,0"
              Background="{DynamicResource Btn_Primary_Background}"
              Foreground="{DynamicResource Btn_Primary_Foreground}"
              BorderThickness="0"
              FontWeight="SemiBold"
              Click="Ok_Click"
              Content="" />
    </StackPanel>
  </Grid>
</Window>
