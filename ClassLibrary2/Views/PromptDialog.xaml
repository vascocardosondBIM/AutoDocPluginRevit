<Window x:Class="AutoDocumentation.Views.PromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=""
        Width="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource App_Background}"
        Foreground="{DynamicResource App_Foreground}"
        ShowInTaskbar="False">
  <Grid Margin="18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <TextBlock Grid.Row="0"
               x:Name="PromptLabel"
               TextWrapping="Wrap"
               Foreground="{DynamicResource App_MutedForeground}"
               FontSize="12" />
    <TextBox Grid.Row="1"
             x:Name="InputTextBox"
             Margin="0,10,0,16"
             Padding="10,8"
             FontSize="13"
             Background="{DynamicResource Surface_Default}"
             Foreground="{DynamicResource App_Foreground}"
             BorderBrush="{DynamicResource Border_Default}"
             CaretBrush="{DynamicResource App_Foreground}" />
    <StackPanel Grid.Row="2"
                Orientation="Horizontal"
                HorizontalAlignment="Right">
      <Button x:Name="CancelButton"
              MinWidth="96"
              Height="34"
              Margin="0,0,10,0"
              Padding="12,0"
              Background="{DynamicResource Btn_Secondary_Background}"
              Foreground="{DynamicResource Btn_Secondary_Foreground}"
              BorderThickness="0"
              IsCancel="True"
              Click="Cancel_Click"
              Content="" />
      <Button x:Name="OkButton"
              MinWidth="96"
              Height="34"
              Padding="12,0"
              Background="{DynamicResource Btn_Primary_Background}"
              Foreground="{DynamicResource Btn_Primary_Foreground}"
              BorderThickness="0"
              FontWeight="SemiBold"
              Click="Ok_Click"
              Content="" />
    </StackPanel>
  </Grid>
</Window>
