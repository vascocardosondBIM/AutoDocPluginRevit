<Window x:Class="AutoDocumentation.Views.PromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Entrada"
        Width="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FF1C1C1E"
        Foreground="#FFF2F2F7"
        ShowInTaskbar="False">
  <Grid Margin="18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <TextBlock Grid.Row="0"
               x:Name="PromptLabel"
               TextWrapping="Wrap"
               Foreground="#FFAEAEB2"
               FontSize="12" />
    <TextBox Grid.Row="1"
             x:Name="InputTextBox"
             Margin="0,10,0,16"
             Padding="10,8"
             FontSize="13"
             Background="#FF2C2C2E"
             Foreground="#FFF2F2F7"
             BorderBrush="#FF48484A"
             CaretBrush="#FFF2F2F7" />
    <StackPanel Grid.Row="2"
                Orientation="Horizontal"
                HorizontalAlignment="Right">
      <Button MinWidth="96"
              Height="34"
              Margin="0,0,10,0"
              Padding="12,0"
              Background="#FF3A3A3C"
              Foreground="#FFF2F2F7"
              BorderThickness="0"
              IsCancel="True"
              Click="Cancel_Click"
              Content="Cancelar" />
      <Button MinWidth="96"
              Height="34"
              Padding="12,0"
              Background="#FF0A84FF"
              Foreground="White"
              BorderThickness="0"
              FontWeight="SemiBold"
              Click="Ok_Click"
              Content="OK" />
    </StackPanel>
  </Grid>
</Window>
