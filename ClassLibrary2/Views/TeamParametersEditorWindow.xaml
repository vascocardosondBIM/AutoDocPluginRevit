<Window x:Class="AutoDocumentation.Views.TeamParametersEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=""
        Width="800"
        Height="480"
        MinHeight="360"
        MinWidth="740"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{DynamicResource App_Background}"
        Foreground="{DynamicResource App_Foreground}"
        TextOptions.TextFormattingMode="Display">
  <Window.Resources>
    <Style x:Key="AssistantSecondaryButtonStyle" TargetType="Button">
      <Setter Property="Background" Value="{DynamicResource Btn_Secondary_Background}" />
      <Setter Property="Foreground" Value="{DynamicResource Btn_Secondary_Foreground}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FocusVisualStyle" Value="{x:Null}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Chrome"
                    Background="{TemplateBinding Background}"
                    BorderThickness="0"
                    Padding="{TemplateBinding Padding}"
                    SnapsToDevicePixels="True">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                RecognizesAccessKey="True"
                                TextElement.Foreground="{TemplateBinding Foreground}" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Btn_Secondary_DisabledBg}" />
                <Setter Property="Foreground" Value="{DynamicResource Btn_Secondary_DisabledFg}" />
                <Setter Property="Cursor" Value="Arrow" />
              </Trigger>
              <MultiTrigger>
                <MultiTrigger.Conditions>
                  <Condition Property="IsEnabled" Value="True" />
                  <Condition Property="IsMouseOver" Value="True" />
                </MultiTrigger.Conditions>
                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Btn_Secondary_Hover}" />
              </MultiTrigger>
              <MultiTrigger>
                <MultiTrigger.Conditions>
                  <Condition Property="IsEnabled" Value="True" />
                  <Condition Property="IsPressed" Value="True" />
                </MultiTrigger.Conditions>
                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Btn_Secondary_Pressed}" />
              </MultiTrigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="AssistantDangerButtonStyle" TargetType="Button">
      <Setter Property="Background" Value="{DynamicResource Btn_Danger_Background}" />
      <Setter Property="Foreground" Value="{DynamicResource Btn_Danger_Foreground}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FocusVisualStyle" Value="{x:Null}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Chrome"
                    Background="{TemplateBinding Background}"
                    BorderThickness="0"
                    Padding="{TemplateBinding Padding}"
                    SnapsToDevicePixels="True">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                RecognizesAccessKey="True"
                                TextElement.Foreground="{TemplateBinding Foreground}" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Btn_Danger_DisabledBg}" />
                <Setter Property="Foreground" Value="{DynamicResource Btn_Danger_DisabledFg}" />
                <Setter Property="Cursor" Value="Arrow" />
              </Trigger>
              <MultiTrigger>
                <MultiTrigger.Conditions>
                  <Condition Property="IsEnabled" Value="True" />
                  <Condition Property="IsMouseOver" Value="True" />
                </MultiTrigger.Conditions>
                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Btn_Danger_Hover}" />
              </MultiTrigger>
              <MultiTrigger>
                <MultiTrigger.Conditions>
                  <Condition Property="IsEnabled" Value="True" />
                  <Condition Property="IsPressed" Value="True" />
                </MultiTrigger.Conditions>
                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Btn_Danger_Pressed}" />
              </MultiTrigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="AssistantPrimaryButtonStyle" TargetType="Button">
      <Setter Property="Background" Value="{DynamicResource Btn_Primary_Background}" />
      <Setter Property="Foreground" Value="{DynamicResource Btn_Primary_Foreground}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FocusVisualStyle" Value="{x:Null}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Chrome"
                    Background="{TemplateBinding Background}"
                    BorderThickness="0"
                    Padding="{TemplateBinding Padding}"
                    SnapsToDevicePixels="True">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                RecognizesAccessKey="True"
                                TextElement.Foreground="{TemplateBinding Foreground}" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Btn_Primary_DisabledBg}" />
                <Setter Property="Foreground" Value="{DynamicResource Btn_Primary_DisabledFg}" />
                <Setter Property="Cursor" Value="Arrow" />
              </Trigger>
              <MultiTrigger>
                <MultiTrigger.Conditions>
                  <Condition Property="IsEnabled" Value="True" />
                  <Condition Property="IsMouseOver" Value="True" />
                </MultiTrigger.Conditions>
                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Btn_Primary_Hover}" />
              </MultiTrigger>
              <MultiTrigger>
                <MultiTrigger.Conditions>
                  <Condition Property="IsEnabled" Value="True" />
                  <Condition Property="IsPressed" Value="True" />
                </MultiTrigger.Conditions>
                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Btn_Primary_Pressed}" />
              </MultiTrigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0"
               x:Name="HeaderText"
               Text=""
               FontSize="16"
               FontWeight="SemiBold" />

    <TextBlock Grid.Row="1"
               Margin="0,8,0,10"
               TextWrapping="Wrap"
               Foreground="{DynamicResource App_MutedForeground}"
               FontSize="12"
               x:Name="SelectionSummaryText" />

    <DataGrid Grid.Row="2"
              x:Name="ParametersDataGrid"
              SelectionChanged="ParametersDataGrid_SelectionChanged"
              ItemsSource="{Binding Rows}"
              AutoGenerateColumns="False"
              CanUserAddRows="False"
              CanUserDeleteRows="False"
              HeadersVisibility="Column"
              SelectionMode="Extended"
              GridLinesVisibility="Horizontal"
              RowHeight="32"
              Background="{DynamicResource DataGrid_Background}"
              Foreground="{DynamicResource DataGrid_Foreground}"
              RowBackground="{DynamicResource DataGrid_RowBackground}"
              AlternatingRowBackground="{DynamicResource DataGrid_AltRowBackground}"
              BorderBrush="{DynamicResource Border_Default}"
              HorizontalGridLinesBrush="{DynamicResource DataGrid_GridLine}">
      <DataGrid.Resources>
        <Style x:Key="ThemedDataGridTextBlockStyle" TargetType="TextBlock">
          <Setter Property="Foreground" Value="{DynamicResource DataGrid_Foreground}" />
          <Setter Property="Background" Value="Transparent" />
          <Setter Property="Padding" Value="6,4" />
          <Setter Property="VerticalAlignment" Value="Center" />
          <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>
        <Style x:Key="ThemedDataGridTextBoxStyle" TargetType="TextBox">
          <Setter Property="Foreground" Value="{DynamicResource DataGrid_TextBoxForeground}" />
          <Setter Property="Background" Value="{DynamicResource DataGrid_TextBoxBackground}" />
          <Setter Property="BorderBrush" Value="{DynamicResource DataGrid_TextBoxBorder}" />
          <Setter Property="CaretBrush" Value="{DynamicResource DataGrid_TextBoxForeground}" />
          <Setter Property="Padding" Value="6,4" />
          <Setter Property="SelectionBrush" Value="{DynamicResource DataGrid_TextSelection}" />
        </Style>
      </DataGrid.Resources>
      <DataGrid.ColumnHeaderStyle>
        <Style TargetType="DataGridColumnHeader">
          <Setter Property="Background" Value="{DynamicResource DataGrid_HeaderBackground}" />
          <Setter Property="Foreground" Value="{DynamicResource DataGrid_HeaderForeground}" />
          <Setter Property="Padding" Value="10,8" />
          <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
      </DataGrid.ColumnHeaderStyle>
      <DataGrid.RowStyle>
        <Style TargetType="DataGridRow">
          <Setter Property="Background" Value="{DynamicResource DataGrid_RowBackground}" />
          <Setter Property="Foreground" Value="{DynamicResource DataGrid_Foreground}" />
          <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
              <Setter Property="Background" Value="{DynamicResource DataGrid_RowSelected}" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter Property="Background" Value="{DynamicResource DataGrid_RowHover}" />
            </Trigger>
          </Style.Triggers>
        </Style>
      </DataGrid.RowStyle>
      <DataGrid.CellStyle>
        <Style TargetType="DataGridCell">
          <Setter Property="Background" Value="{DynamicResource DataGrid_RowBackground}" />
          <Setter Property="Foreground" Value="{DynamicResource DataGrid_Foreground}" />
          <Setter Property="BorderBrush" Value="{DynamicResource DataGrid_GridLine}" />
          <Setter Property="BorderThickness" Value="0" />
          <Setter Property="Padding" Value="2" />
          <Setter Property="Template">
            <Setter.Value>
              <ControlTemplate TargetType="DataGridCell">
                <Border x:Name="CellBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        Padding="{TemplateBinding Padding}"
                        SnapsToDevicePixels="True">
                  <ContentPresenter VerticalAlignment="Center"
                                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                </Border>
                <ControlTemplate.Triggers>
                  <Trigger Property="IsSelected" Value="True">
                    <Setter TargetName="CellBorder" Property="Background" Value="{DynamicResource DataGrid_CellSelected}" />
                  </Trigger>
                </ControlTemplate.Triggers>
              </ControlTemplate>
            </Setter.Value>
          </Setter>
        </Style>
      </DataGrid.CellStyle>
      <DataGrid.Columns>
        <DataGridTextColumn x:Name="ColParameterName"
                            Binding="{Binding ParameterName}"
                            Width="2*"
                            IsReadOnly="True"
                            ElementStyle="{StaticResource ThemedDataGridTextBlockStyle}" />
        <DataGridTextColumn x:Name="ColKind"
                            Binding="{Binding KindDisplay}"
                            Width="*"
                            IsReadOnly="True"
                            ElementStyle="{StaticResource ThemedDataGridTextBlockStyle}" />
        <DataGridTextColumn x:Name="ColValue"
                            Binding="{Binding ValueText, UpdateSourceTrigger=PropertyChanged}"
                            Width="2*"
                            IsReadOnly="False"
                            ElementStyle="{StaticResource ThemedDataGridTextBlockStyle}"
                            EditingElementStyle="{StaticResource ThemedDataGridTextBoxStyle}" />
      </DataGrid.Columns>
    </DataGrid>

    <Grid Grid.Row="3"
          Margin="0,14,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <WrapPanel Grid.Column="0"
                 Orientation="Horizontal"
                 VerticalAlignment="Center">
        <Button x:Name="CreateParameterButton"
                MinWidth="120"
                Height="34"
                Margin="0,0,10,8"
                Padding="12,0"
                Style="{StaticResource AssistantSecondaryButtonStyle}"
                Click="CreateParameterButton_Click"
                Content="" />
        <Button x:Name="ReportButton"
                MinWidth="100"
                Height="34"
                Margin="0,0,10,8"
                Padding="12,0"
                Style="{StaticResource AssistantSecondaryButtonStyle}"
                Click="ReportButton_Click"
                Content="" />
        <Button x:Name="ExportParameterPackButton"
                MinWidth="118"
                Height="34"
                Margin="0,0,10,8"
                Padding="12,0"
                Style="{StaticResource AssistantSecondaryButtonStyle}"
                IsEnabled="False"
                Click="ExportParameterPackButton_Click"
                Content="" />
        <Button x:Name="ImportParameterPackButton"
                MinWidth="120"
                Height="34"
                Margin="0,0,10,8"
                Padding="12,0"
                Style="{StaticResource AssistantSecondaryButtonStyle}"
                Click="ImportParameterPackButton_Click"
                Content="" />
        <Button x:Name="EditParameterButton"
                MinWidth="88"
                Height="34"
                Margin="0,0,10,8"
                Padding="12,0"
                Style="{StaticResource AssistantSecondaryButtonStyle}"
                IsEnabled="False"
                Click="EditParameterButton_Click"
                Content="" />
        <Button x:Name="DeleteParameterButton"
                MinWidth="96"
                Height="34"
                Margin="0,0,10,8"
                Padding="12,0"
                Style="{StaticResource AssistantDangerButtonStyle}"
                IsEnabled="False"
                Click="DeleteParameterButton_Click"
                Content="" />
      </WrapPanel>
      <StackPanel Grid.Column="1"
                  Orientation="Horizontal"
                  VerticalAlignment="Center">
        <Button x:Name="ApplyButton"
                MinWidth="96"
                Height="34"
                Margin="0,0,10,0"
                Padding="12,0"
                Style="{StaticResource AssistantPrimaryButtonStyle}"
                Click="ApplyButton_Click"
                Content="" />
        <Button x:Name="CloseButton"
                MinWidth="88"
                Height="34"
                Padding="12,0"
                Style="{StaticResource AssistantSecondaryButtonStyle}"
                Click="CloseButton_Click"
                Content="" />
      </StackPanel>
    </Grid>
  </Grid>
</Window>
